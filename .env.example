# =============================================================================
# Blueprint — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=blueprint
POSTGRES_USER=blueprint
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# --- Ollama (Local LLM) ---
OLLAMA_BASE_URL=http://ollama:11434

# --- Service Intervals (minutes) ---
SCOUT_INTERVAL_MINUTES=60
EVALUATOR_INTERVAL_MINUTES=5
EVALUATOR_STALENESS_DAYS=14

# --- Scout Overrides ---
SCOUT_MAX_AGE_DAYS=30
SCOUT_MAX_DISCOVERY_PROBES=10
# SCOUT_ROLES=Principal Architect,Staff Engineer,Data Scientist

# --- Company Sourcing ---
SCOUT_CONTACT_EMAIL=                            # Required for SEC EDGAR User-Agent
SCOUT_SOURCING_INTERVAL_HOURS=168               # Re-source frequency (default: weekly)
# SCOUT_OSHA_INSPECTION_URL=                    # Override OSHA inspection CSV download URL

# --- Catalog Filtering ---
# SCOUT_MIN_EMPLOYEES=                          # Min employee count for catalog phase
# SCOUT_MAX_EMPLOYEES=                          # Max employee count
# SCOUT_FOUNDED_AFTER=                          # Year (e.g. 2000)
# SCOUT_FILTER_STATES=                          # Comma-separated state codes (e.g. CO,CA)
# SCOUT_FILTER_INDUSTRIES=                      # Comma-separated industry names

# --- Dashboard ---
DASHBOARD_PORT=3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here

# --- Authentik OIDC (uncomment when ready) ---
# AUTHENTIK_ISSUER=https://auth.yourdomain.com/application/o/blueprint/
# AUTHENTIK_CLIENT_ID=
# AUTHENTIK_CLIENT_SECRET=
