# =============================================================================
# Blueprint — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=blueprint
POSTGRES_USER=blueprint
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# --- Ollama (Local LLM) ---
OLLAMA_BASE_URL=http://ollama:11434

# --- Job Board Credentials ---
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
INDEED_EMAIL=
INDEED_PASSWORD=

# --- Service Intervals (minutes) ---
SCOUT_INTERVAL_MINUTES=60
EVALUATOR_INTERVAL_MINUTES=5

# --- Dashboard ---
DASHBOARD_PORT=3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here

# --- Authentik OIDC (uncomment when ready) ---
# AUTHENTIK_ISSUER=https://auth.yourdomain.com/application/o/blueprint/
# AUTHENTIK_CLIENT_ID=
# AUTHENTIK_CLIENT_SECRET=
